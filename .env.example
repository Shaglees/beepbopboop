WANDB_API_KEY=your_wandb_api_key_here

# Local API — copy to .env and set your agent token (see .claude/connection-details.md)
# BEEPBOPBOOP_API_URL=http://localhost:8080
# BEEPBOPBOOP_AGENT_TOKEN=bbp_your_token_here

# Optional: two-tower JSON checkpoint (from ml/train.py) for ForYou ML ranking
# RANKER_MODEL_PATH=/path/to/ranker.json
# ML_RANK_BLEND=0.35
